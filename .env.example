# ============================================================
# FX Tracker — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- Backend (backend/.env) ---------------------------------

# Your API key from https://www.exchangerate-api.com/
# Leave as "demo" to use deterministic mock data (no key needed).
EXCHANGE_RATE_API_KEY=demo

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Maximum number of active alerts allowed
MAX_ALERTS_PER_USER=10

# How often (in seconds) the server checks for triggered alerts
ALERT_CHECK_INTERVAL_SECONDS=300

# --- Frontend (frontend/.env) --------------------------------

# Base URL of the backend API (used during development when not proxying)
VITE_API_BASE_URL=/api/v1
