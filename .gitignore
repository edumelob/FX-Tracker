# ============================================================
# FX Tracker — .gitignore
# ============================================================

# --- Environment & secrets ---
.env
*.env
!.env.example

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
.venv/
ENV/
dist/
build/
*.egg-info/
.eggs/
pip-wheel-metadata/
*.pyo

# --- Pytest / coverage ---
.pytest_cache/
.coverage
htmlcov/
coverage.xml
*.cover

# --- Node / npm ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json.bak

# --- Vite build output ---
frontend/dist/
frontend/.vite/

# --- IDEs ---
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# --- Logs ---
*.log
logs/
